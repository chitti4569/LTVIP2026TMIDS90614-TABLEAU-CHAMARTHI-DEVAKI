    <dashboard name='Story 1' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Global Smartphone Overview</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='964' maxwidth='1016' minheight='964' minwidth='1016' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98426' x='787' y='830'>
            <zone h='4357' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='5187' />
            <zone h='83506' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='15664'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='false'>
                <story-points>
                  <story-point caption='This dashboard provides an overview of the global smartphone market, showing annual revenue trends and country-wise market share to understand overall industry performance.' captured-sheet='Dashboard 1' id='1' />
                  <story-point caption='This view focuses on India’s smartphone market, highlighting the best-selling models and major brands dominating the market in 2022.' captured-sheet='Dashboard 2' id='2' />
                  <story-point caption='This dashboard compares smartphone prices across different brands, helping to analyze price differences and market positioning.' captured-sheet='Brand Price Comparision' id='3' />
